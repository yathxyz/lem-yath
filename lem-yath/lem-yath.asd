                             (:file "agenda-bulk")
                             (:file "agenda-undo-command")
                             (:file "agenda-filter")
                             (:file "agenda-restriction")
                             (:file "agenda-query")
                             (:file "agenda-stuck")
                             (:file "agenda-view")
                             (:file "agenda-time-grid")
                             (:file "citar")
                             (:file "devdocs")
                             (:file "elfeed")
                             (:file "notmuch")
                             (:file "pg")
                             (:file "salta")
                             (:file "timemachine")
                             (:file "llm-cli")
                             (:file "llm-http")
                             (:file "llm-oauth")
                             (:file "llm-presets")
                             (:file "claude-bridge")
                             (:file "claude-code")))
               (:file "llm-claude-sessions")
               (:file "llm-claude-blocks")
               (:file "llm-codex-models")
