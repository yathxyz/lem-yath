 (defun add-message-to-outbox (connection message)
   (send-and-notify connection (connection-outbox connection) message))

+(defun remove-callback-for-id (connection id)
+  "Remove the response callback for ID, returning true when one existed."
+  (bt:with-recursive-lock-held ((connection-response-lock connection))
+    (remhash id (connection-response-callback connection))))
+
