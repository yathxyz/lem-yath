+static void terminate_shell(pid_t pid)
+{
+  int child_status;
+  pid_t result;
+
+  if (pid <= 0) return;
+  result = waitpid(pid, &child_status, WNOHANG);
+  if (result == pid || (result < 0 && errno == ECHILD)) return;
+
+  kill(-pid, SIGKILL);
+  kill(pid, SIGKILL);
+  do {
+    result = waitpid(pid, &child_status, 0);
+  } while (result < 0 && errno == EINTR);
+}
