-    (let ((string (delete/after-change-function point #'call-next-method)))
-      (when (plusp (length string))
-        (let ((edit (make-edit :delete-string position string)))
-          (cond ((undo-tree-replaying-buffer-p buffer))
-                ((inhibit-undo-p)
-                 (recompute-undo-position-offset buffer edit))
-                ((buffer-%enable-undo-p buffer)
-                 (push-undo buffer edit)))))
-      string)))
+    (flet ((record (string)
+             (when (plusp (length string))
+               (let ((edit (make-edit :delete-string position string)))
+                 (cond ((undo-tree-replaying-buffer-p buffer))
+                       ((inhibit-undo-p)
+                        (recompute-undo-position-offset buffer edit))
+                       ((buffer-%enable-undo-p buffer)
+                        (push-undo buffer edit)))))))
+      (delete/after-change-function
+       point #'call-next-method #'record))))
