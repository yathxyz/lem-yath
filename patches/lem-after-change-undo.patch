diff --git a/src/buffer/internal/buffer-insert.lisp b/src/buffer/internal/buffer-insert.lisp
--- a/src/buffer/internal/buffer-insert.lisp
+++ b/src/buffer/internal/buffer-insert.lisp
@@ -168,23 +168,33 @@
        (or (variable-value 'after-change-functions :buffer buffer)
            (variable-value 'after-change-functions :global))))
 
-(defun insert/after-change-function (point arg call-next-method)
-  (if (need-to-call-after-change-functions-p (point-buffer point))
-      (with-point ((start point))
-        (prog1 (funcall call-next-method)
-          (with-point ((end start))
-            (character-offset end arg)
-            (call-after-change-functions (point-buffer point) start end 0))))
-      (funcall call-next-method)))
+(defun insert/after-change-function
+    (point arg call-next-method record-function)
+  ;; The low-level mutation has completed before an after-change hook runs.
+  ;; Record it before invoking hooks so recursive edits retain chronological
+  ;; order and a throwing hook cannot leave changed text outside history.
+  (with-point ((start point))
+    (let ((result (funcall call-next-method)))
+      (funcall record-function result)
+      (when (need-to-call-after-change-functions-p
+             (point-buffer point))
+        (with-point ((end start))
+          (character-offset end arg)
+          (call-after-change-functions
+           (point-buffer point) start end 0)))
+      result)))
 
-(defun delete/after-change-function (point call-next-method)
-  (if (need-to-call-after-change-functions-p (point-buffer point))
-      (let ((string (funcall call-next-method)))
-        (with-point ((start point)
-                     (end point))
-          (call-after-change-functions (point-buffer point) start end (length string)))
-        string)
-      (funcall call-next-method)))
+(defun delete/after-change-function
+    (point call-next-method record-function)
+  (let ((string (funcall call-next-method)))
+    (funcall record-function string)
+    (when (need-to-call-after-change-functions-p
+           (point-buffer point))
+      (with-point ((start point)
+                   (end point))
+        (call-after-change-functions
+         (point-buffer point) start end (length string))))
+    string))
 
 (defmethod insert-string/point :around (point string)
   (call-before-change-functions point string)
@@ -192,17 +202,16 @@
          (position (position-at-point point)))
     (when (buffer-%enable-undo-p buffer)
       (ensure-buffer-undo-tree buffer))
-    (let ((result
-            (insert/after-change-function point (length string)
-                                          #'call-next-method)))
-      (when (plusp (length result))
-        (let ((edit (make-edit :insert-string position result)))
-          (cond ((undo-tree-replaying-buffer-p buffer))
-                ((inhibit-undo-p)
-                 (recompute-undo-position-offset buffer edit))
-                ((buffer-%enable-undo-p buffer)
-                 (push-undo buffer edit)))))
-      result)))
+    (flet ((record (result)
+             (when (plusp (length result))
+               (let ((edit (make-edit :insert-string position result)))
+                 (cond ((undo-tree-replaying-buffer-p buffer))
+                       ((inhibit-undo-p)
+                        (recompute-undo-position-offset buffer edit))
+                       ((buffer-%enable-undo-p buffer)
+                        (push-undo buffer edit)))))))
+      (insert/after-change-function
+       point (length string) #'call-next-method #'record))))
 
 (defmethod delete-char/point :around (point remaining-deletions)
   (call-before-change-functions point remaining-deletions)
@@ -210,12 +219,13 @@
          (position (position-at-point point)))
     (when (buffer-%enable-undo-p buffer)
